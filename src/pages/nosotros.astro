---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
---

<Layout title="Nosotros">
  <Navbar />

  <section class="bg-gradient-to-br from-primary to-secondary py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Quiénes Somos</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">Empresa familiar con trayectoria: 60 años junto a usted.</p>
    </div>
  </section>

  <section class="py-20 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-primary mb-4">Quiénes Somos</h2>
        <h3 class="text-2xl font-semibold text-accent mb-6">Empresa familiar con trayectoria: 60 años junto a usted.</h3>
        <p class="text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Somos una empresa familiar con más de 60 años de experiencia en el servicio funerario. Acompañamos a cada familia con respeto, compromiso y una atención cercana en cada etapa. Nuestra historia es su mayor garantía de tranquilidad.
        </p>
      </div>
      <ImageCarousel 
        images={["/sepelios_pinier.jpeg", "/sepelios_santaMag.jpeg"]} 
        alt="Nuestras sedes" 
        height="h-80" 
      />
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="bg-gradient-to-br from-primary to-secondary p-8 rounded-xl text-white text-center">
          <div class="text-4xl font-bold text-accent">60+</div>
          <div class="text-gray-300">Años</div>
        </div>
        <div class="bg-gradient-to-br from-primary to-secondary p-8 rounded-xl text-white text-center">
          <div class="text-4xl font-bold text-accent">5000+</div>
          <div class="text-gray-300">Servicios</div>
        </div>
        <div class="bg-gradient-to-br from-primary to-secondary p-8 rounded-xl text-white text-center">
          <div class="text-4xl font-bold text-accent">2</div>
          <div class="text-gray-300">Sedes</div>
        </div>
        <div class="bg-gradient-to-br from-primary to-secondary p-8 rounded-xl text-white text-center">
          <div class="text-4xl font-bold text-accent">24/7</div>
          <div class="text-gray-300">Atención</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-primary text-white text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Sesenta años cuidando lo más importante: su recuerdo.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 text-left">
        <div class="bg-white/10 p-6 rounded-xl">
          <h3 class="text-xl font-semibold text-accent mb-2">Sepelios Pinier</h3>
          <p class="text-gray-300">Av. S. Martín 2902</p>
          <p class="text-gray-300">C1416, Ciudad Autónoma de Buenos Aires</p>
        </div>
        <div class="bg-white/10 p-6 rounded-xl">
          <h3 class="text-xl font-semibold text-accent mb-2">Cochería Santa Magdalena</h3>
          <p class="text-gray-300">Av. Salvador María del Carril 2483</p>
          <p class="text-gray-300">C1419GZD, Ciudad Autónoma de Buenos Aires</p>
        </div>
      </div>

      <p class="text-xl text-accent mt-8 font-semibold">Su confianza es nuestro mayor compromiso.</p>

      <a href="#contacto" class="inline-flex items-center bg-accent text-primary px-8 py-4 rounded-lg font-semibold hover:bg-accent/90 transition-colors mt-8">
        Contactanos Ahora
      </a>
    </div>
  </section>

  <section id="contacto" class="py-20 bg-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Contacto</h2>
        <p class="text-gray-300 text-lg">Estamos disponibles las 24 horas para atenderte.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h3 class="text-xl font-semibold text-accent mb-6">Envianos un mensaje</h3>
          <form class="space-y-4" action="https://formsubmit.co/administracionfuneraria@gmail.com" method="POST">
            <input type="hidden" name="_subject" value="Nuevo mensaje desde la web" />
            <div>
              <label class="block text-sm mb-1">Nombre</label>
              <input type="text" name="nombre" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-accent" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-sm mb-1">Teléfono</label>
              <input type="tel" name="telefono" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-accent" placeholder="Tu teléfono" />
            </div>
            <div>
              <label class="block text-sm mb-1">Mensaje</label>
              <textarea name="mensaje" rows="4" required class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-accent" placeholder="¿En qué podemos ayudarte?"></textarea>
            </div>
            <button type="submit" class="w-full bg-accent text-primary px-6 py-3 rounded-lg font-bold hover:bg-accent/90 transition-colors">
              Enviar Mensaje
            </button>
          </form>

          <div class="mt-8 bg-white/10 p-6 rounded-xl">
            <h3 class="text-xl font-semibold text-accent mb-4">📞 Teléfono de Guardia 24hs</h3>
            <a href="tel:+5491139055121" class="text-3xl font-bold hover:underline block mb-2">
              (11) 3905-5121
            </a>
            <p class="text-gray-300 text-sm">Su confianza es nuestro mayor compromiso.</p>
          </div>
        </div>

        <div class="space-y-8">
          <div class="bg-white/10 p-6 rounded-xl">
            <h3 class="text-xl font-semibold text-accent mb-4">Sepelios Pinier</h3>
            <p class="text-gray-300 mb-2">Av. S. Martín 2902</p>
            <p class="text-gray-300 mb-2">C1416, Ciudad Autónoma de Buenos Aires</p>
          </div>

          <div class="bg-white/10 p-6 rounded-xl">
            <h3 class="text-xl font-semibold text-accent mb-4">Cochería Santa Magdalena</h3>
            <p class="text-gray-300 mb-2">Av. Salvador María del Carril 2483</p>
            <p class="text-gray-300 mb-2">C1419GZD, Ciudad Autónoma de Buenos Aires</p>
          </div>

          <a href="https://wa.me/5491139055121?text=Hola,%20necesito%20más%20información%20sobre%20los%20servicios%20funerarios." target="_blank" class="flex items-center justify-center gap-2 bg-[#25D366] text-white px-6 py-4 rounded-lg font-bold hover:bg-[#20BD5A] transition-colors w-full">
            💬 Contactar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>