---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto">
  <Navbar />

  <section class="bg-gradient-to-br from-primary to-secondary py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Contacto</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">Sesenta años cuidando lo más importante: su recuerdo.</p>
    </div>
  </section>

  <section class="py-20 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-primary mb-8">Envíanos un mensaje</h2>
          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Nombre completo</label>
                <input type="text" id="nombre" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="Tu nombre" />
              </div>
              <div>
                <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
                <input type="tel" id="telefono" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="Tu teléfono" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
              <input type="email" id="email" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="tu@email.com" />
            </div>
            <div>
              <label for="asunto" class="block text-sm font-medium text-gray-700 mb-2">Asunto</label>
              <select id="asunto" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent">
                <option value="">Selecciona un asunto</option>
                <option value="servicio">Información de servicios</option>
                <option value="emergencia">Emergencia 24h</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">Mensaje</label>
              <textarea id="mensaje" rows="5" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent" placeholder="¿En qué podemos ayudarte?"></textarea>
            </div>
            <button type="submit" class="w-full bg-accent text-primary py-4 rounded-lg font-semibold hover:bg-accent/90 transition-colors">
              Enviar Mensaje
            </button>
          </form>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-primary mb-8">Nuestras ubicaciones</h2>
          
          <div class="bg-white rounded-xl shadow-md p-6 mb-6">
            <h3 class="text-lg font-semibold text-primary mb-4">Sepelios Pinier</h3>
            <p class="text-gray-600 mb-2">Av. S. Martín 2902</p>
            <p class="text-gray-600 mb-2">C1416, Ciudad Autónoma de Buenos Aires</p>
            <p class="text-accent mt-4 text-sm font-semibold">Contáctenos para más información</p>
          </div>

          <div class="bg-white rounded-xl shadow-md p-6 mb-6">
            <h3 class="text-lg font-semibold text-primary mb-4">Cochería Santa Magdalena</h3>
            <p class="text-gray-600 mb-2">Av. Salvador María del Carril 2483</p>
            <p class="text-gray-600 mb-2">C1419GZD, Ciudad Autónoma de Buenos Aires</p>
            <p class="text-accent mt-4 text-sm font-semibold">Contáctenos para más información</p>
          </div>

          <div class="bg-white rounded-xl shadow-md p-8">
            <h3 class="text-lg font-semibold text-primary mb-4">📞 Teléfono de guardia 24hs</h3>
            <a href="tel:+5491139055121" class="text-2xl font-bold text-accent hover:underline">
              (11) 3905-5121
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">Emergencia? Llámanos ahora</h2>
      <p class="text-gray-300 mb-8">Nuestro equipo de emergencias está disponible las 24 horas.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/5491139055121?text=Hola,%20necesito%20más%20información%20sobre%20los%20servicios%20funerarios." target="_blank" class="inline-flex items-center bg-[#25D366] text-white px-8 py-4 rounded-lg font-semibold hover:bg-[#20BD5A] transition-colors text-xl">
          💬 Atención con Adrián
        </a>
        <a href="tel:+5491139055121" class="inline-flex items-center bg-accent text-primary px-8 py-4 rounded-lg font-semibold hover:bg-accent/90 transition-colors text-xl">
          📞 Llamar
        </a>
      </div>
      <p class="mt-8 text-lg text-gray-300">Su confianza es nuestro mayor compromiso.</p>
    </div>
  </section>

  <Footer />
</Layout>