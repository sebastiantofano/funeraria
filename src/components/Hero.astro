---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
}

const { title, subtitle, ctaText = 'Ver Servicios', ctaLink = '#servicios', backgroundImage } = Astro.props;
---

<section class="relative bg-gradient-to-br from-primary to-secondary min-h-[80vh] flex items-center overflow-hidden">
  {backgroundImage && (
    <div class="absolute inset-0">
      <img src={backgroundImage} alt="Funeraria" class="w-full h-full object-cover opacity-30" />
    </div>
  )}
  <div class="absolute inset-0 bg-black/40"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-accent/20 text-accent px-4 py-2 rounded-full text-sm mb-6">
        <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
        Servicio disponible 24 horas
      </div>
      
      <p class="text-3xl md:text-4xl text-accent font-bold uppercase tracking-widest mb-2">Casa de Sepelios</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl text-white font-bold mb-6 leading-tight">
        {title}
      </h1>
      
      <p class="text-xl text-gray-200 mb-8 leading-relaxed">
        {subtitle}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#servicios" class="inline-flex items-center justify-center bg-accent text-primary px-8 py-4 rounded-lg font-semibold hover:bg-accent/90 transition-colors">
          {ctaText}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#contacto" class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-primary transition-colors">
          Contactanos
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-light to-transparent"></div>
</section>