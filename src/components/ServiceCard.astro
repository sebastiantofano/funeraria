---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="service-card bg-white p-8 rounded-xl shadow-md transition-all duration-300 border-t-4 border-accent">
  <div class="w-14 h-14 bg-accent/10 rounded-lg flex items-center justify-center mb-6 text-2xl">
    {icon}
  </div>
  
  <h3 class="text-xl font-semibold text-primary mb-3">{title}</h3>
  
  <p class="text-gray-600 leading-relaxed">
    {description}
  </p>
</div>