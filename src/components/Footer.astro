  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Adrian</h3>
        <p class="text-sm">Servicios funerarios con dignidad y respeto. Su confianza es nuestro mayor compromiso.</p>
      </div>

      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li>📞 (11) 3905-5121</li>
        </ul>
      </div>

      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Horario</h3>
        <ul class="space-y-2 text-sm">
          <li>Atención las 24 horas</li>
          <li class="text-accent">Servicio disponible 24/7</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
